# DefectDojo Configuration
# ========================

# Django version for DefectDojo
DJANGO_VERSION=latest

# Nginx version
NGINX_VERSION=latest

# Port configuration
DD_PORT=18083
DD_UWSGI_HOST=dojo-uwsgi
DD_UWSGI_PORT=3031

# Nginx metrics enabled
NGINX_METRICS_ENABLED=false

# Database Configuration
DD_DATABASE_NAME=defectdojo
DD_DATABASE_USER=defectdojo
DD_DATABASE_PASSWORD=defectdojo
DD_DATABASE_URL=postgresql://defectdojo:defectdojo@dojo-postgres:5432/defectdojo
DD_DATABASE_READINESS_TIMEOUT=30

# Cache/Message Broker Configuration
DD_CELERY_BROKER_URL=redis://dojo-valkey:6379/0

# Security Configuration
DD_SECRET_KEY=hhZCp@D28z!n@NED*yB!ROMt+WzsY*iq
DD_CREDENTIAL_AES_256_KEY=&91a*agLqesc*0DJ+2*bAbsUZfR*4nLw

# Host Configuration
DD_ALLOWED_HOSTS=localhost,127.0.0.1,dojo-nginx,*.app.github.dev

# CSRF Configuration (for GitHub Codespaces and local development)
DD_CSRF_TRUSTED_ORIGINS=https://*.app.github.dev,https://localhost:18083,http://localhost:18083

# Admin User Configuration
DD_ADMIN_USER=admin
DD_ADMIN_MAIL=admin@defectdojo.local
DD_ADMIN_FIRST_NAME=Admin
DD_ADMIN_LAST_NAME=User

# Initialization
DD_INITIALIZE=true

# Media root configuration
DD_MEDIA_ROOT=/app/media

# Dependency-Track Configuration
# ===============================

# API Server port
DTRACK_API_PORT=18081

# UI port
DTRACK_UI_PORT=18082

# Database Configuration for Dependency-Track
DTRACK_DATABASE_NAME=dependencytrack
DTRACK_DATABASE_USER=deptrack
DTRACK_DATABASE_PASSWORD=deptrack
DTRACK_DATABASE_URL=postgresql://deptrack:deptrack@dtrack-postgres:5432/dependencytrack
